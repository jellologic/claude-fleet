# claude-fleet per-repo config. Copy to .fleet/config.sh and customise.
# Sourced by the coordination scripts. Everything here is OPTIONAL — sensible
# defaults apply if you leave it unset. The two functions at the bottom are the
# only stack-specific bits; the rest of the system is stack-agnostic.

# --- Branch policy --------------------------------------------------------
# FLEET_MAIN="main"
# FLEET_PROTECTED_RE='^(main|master|release/.*)$'         # never commit/push here
# FLEET_BRANCH_RE='^(agent|worktree|pr|lockfile|chore|feat|feature|fix)[/-]'  # allowed prefixes
# FLEET_LOCK_BRANCH_RE='^(lockfile|chore)[/-]'            # branches allowed to touch the lockfile

# --- Dependency serialization (optional) ----------------------------------
# Serialize lockfile edits to a single lockfile/* branch, and (in the ownership
# gate) couple dep-manifest edits to the lockfile. Leave empty to disable.
# FLEET_LOCKFILE=""              # e.g. bun.lock | Cargo.lock | pnpm-lock.yaml | package-lock.json
# FLEET_DEP_MANIFEST="**/package.json"   # e.g. **/Cargo.toml

# --- Generated files to keep out of commits (egrep, optional) -------------
# FLEET_GENERATED_RE=''          # e.g. (^|/)routeTree\.gen\.ts$

# --- Files copied into every fresh worktree -------------------------------
# FLEET_ENV_FILES=".env .env.local .env.development .env.development.local"

# --- Bootstrap a fresh worktree (cwd = the new worktree root) -------------
# Provision dependencies / run codegen so the worktree is runnable. STACK-SPECIFIC.
fleet_bootstrap() {
  : # no-op by default. Examples:
  #   bun install                                   # JS
  #   bun install && ( cd apps/web && bun run gen )  # JS + codegen
  #   cargo fetch                                    # Rust
  #   pnpm install --frozen-lockfile                 # pnpm
  # GOTCHA: in a fresh worktree, `bun install` may print "no changes" and NOT create
  # node_modules. Guard it:  bun install; [ -d node_modules ] || bun install --force
}

# --- Integration gate (cwd = integration worktree) ------------------------
# Receives changed build "units" as positional args (from fleet_pkg_for); empty
# args means "full tree". Return 0 = pass, non-zero = reject the merge. STACK-SPECIFIC.
# GOTCHA: if your typecheck depends on generated files (e.g. TanStack routeTree.gen.ts,
# GraphQL/Prisma codegen), run BUILD before CHECK-TYPES — as two sequential commands, not
# one `turbo run check-types build` (turbo's arg order is not run order). A merge that ADDS
# routes/codegen will otherwise typecheck against a stale generated file and false-fail.
fleet_gate() {
  echo "    WARNING: fleet_gate not configured — treating merge as PASS (no real check)" >&2
  return 0
  # Examples:
  #   if [ "$#" -eq 0 ]; then bunx turbo run build && bunx turbo run check-types; else
  #     local f=""; for u in "$@"; do f="$f --filter=$u"; done
  #     bunx turbo run build $f && bunx turbo run check-types $f; fi
  #   cargo check --workspace && cargo nextest run --workspace
}

# --- Map a changed file to a build unit for SCOPED gating (optional) ------
# Echo a unit name, or "" to force a full-tree gate. Default: always full.
fleet_pkg_for() {
  echo ""   # e.g. case "$1" in crates/*/*) echo "$(echo "$1"|cut -d/ -f2)";; *) echo "";; esac
}

# --- Generate a COMPILING STUB for a frozen port (`fleet spec stub`) ------
# $1 = the frozen port artifact (a TYPED, machine-checkable file: .d.ts / .pyi / trait /
#      protobuf / OpenAPI — NEVER prose). $2 = the stub path to write. cwd = the repo root.
# WHY: a CONSUMER unit must typecheck and run its own tests on DAY ZERO, without the PROVIDER
# unit existing at all. STVR 2025: "By decoupling the consumer and provider via the contract
# file, the CDC tests don't require running the consumer and the provider simultaneously."
# Stub generation is inherently stack-specific, so it is a hook. Default: a documented NO-OP —
# `fleet spec stub` says loudly that nothing was generated rather than fake it. STACK-SPECIFIC.
fleet_stub_for() {
  :  # no-op by default. Examples:
  #   case "$1" in
  #     *.d.ts) bunx tsx tools/stub-from-dts.ts "$1" > "$2" ;;   # or hand-write a throwing impl
  #     *.pyi)  python3 tools/stub_from_pyi.py "$1" > "$2" ;;
  #     *.proto) protoc --plugin=protoc-gen-stub … ;;
  #   esac
  # The stub only has to COMPILE and satisfy the type-checker. `throw new Error("stub")` /
  # `raise NotImplementedError` bodies are correct here: the STUB is not the implementation,
  # it is the thing that lets a consumer be built before the provider exists.
}

# --- Contract PRE-GATE (optional, but this is where it belongs) -----------
# `fleet spec check` runs the static port proofs + the frozen-port diff proof. It is a fast
# PRE-GATE, NEVER the verdict: contract tests caught 41/53 (77%) of seeded integration defects
# (STVR 2025) and missed nearly every value-range bug — "They could not replace the service
# black-box tests but only complement them." Put it FIRST in fleet_gate, above the real suite:
#   fleet_gate() {
#     .fleet/bin/fleet spec check || return $?     # pre-gate: cheap, static, refuses drift
#     cargo check --workspace && cargo nextest run --workspace   # the ORACLE
#   }
