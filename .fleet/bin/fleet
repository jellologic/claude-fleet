#!/usr/bin/env bash
# claude-fleet -- bug in this file? SELF-REPORT before fixing: understand it, check/file issues at github.com/jellologic/claude-fleet, then propose a fix. ALL outward actions (issue/comment/push) need HUMAN APPROVAL. See SELF-REPORT.md
# claude-fleet dispatcher. Run: .fleet/bin/fleet <command> [args]
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
cmd="${1:-}"; [ $# -gt 0 ] && shift || true
case "$cmd" in
  claim)         exec "$HERE/agent-claim.sh" "$@" ;;
  release)       exec "$HERE/agent-release.sh" "$@" ;;
  done)          exec "$HERE/agent-done.sh" "$@" ;;
  reap|reaper)   exec "$HERE/agent-reaper.sh" "$@" ;;
  delegate)      exec "$HERE/agent-delegate.sh" "$@" ;;
  fronts)        exec "$HERE/fleet-fronts.sh" "$@" ;;
  wt)            exec "$HERE/wt.sh" "$@" ;;
  integrate)     exec "$HERE/fleet-integrate.sh" "$@" ;;
  check)         exec python3 "$HERE/check-claims.py" "$@" ;;
  gate-check)    exec "$HERE/check-gate-integrity.sh" "$@" ;;
  install-hooks) exec "$HERE/install-hooks.sh" "$@" ;;
  ruleset)       exec "$HERE/setup-main-ruleset.sh" "$@" ;;
  stress-ledger) exec "$HERE/stress-ledger.sh" "$@" ;;
  uninstall)     exec sh "$HERE/../uninstall.sh" "$@" ;;
  ""|-h|--help)
    cat <<EOF
claude-fleet — parallel Claude Code agent coordination
usage: fleet <command> [args]
  claim <issue>            atomically claim an issue (branch-ref lock + draft PR)
  release <issue> [--delete-remote]       abandon a claim (returns issue to agent-ready)
  done <issue> [--force|--delete-remote]   post-MERGE cleanup (issue stays closed)
  reap [--stale H|--force|--delete-remote|--dry-run]   reclaim crashed/abandoned claims
  delegate {delegate <wt> "<task>"|feedback <wt> "<fix>"|loop <wt> --until '<check>' "<task>"
            |review <wt> [--reviewers N] [--base <ref>]
            |fanout <manifest.json> [--jobs N] [--dry-run] [--resume]}
                           hand a work-unit to a headless, OS-sandboxed \`claude -p\` worker;
                           \`review\` runs N=2 adversarial diff-only READ-ONLY reviewers whose
                           findings must ship a runnable repro/patch (advisory — never blocks);
                           \`fanout\` runs N units in parallel worktrees and REFUSES a manifest
                           whose units are not provably disjoint (a cap cannot rescue overlap)
  fronts [--oracle '<cmd>'] [--shard-by file|package|dir] [-o <manifest.json>]
         [--max-units N] [--task '<tmpl>'] [--dry-run] [--require-parallel]
                           WORK-FRONT GENERATOR: run the oracle (default \`fleet_gate\`), shard its
                           FAILURES into provably disjoint units, emit a \`fanout\` manifest. The
                           ORACLE decides the decomposition, never a model (Bun sharded ~16k
                           \`cargo check\` errors "grouped by crate"). If every failure traces to one
                           file/package, it says NOT DECOMPOSABLE and emits ONE unit rather than
                           manufacture fake parallelism — that is the Anthropic 16-agent failure.
  wt {new <task>|bootstrap|rebase|reap <name>|list|prune}
  integrate <integ-branch> <branch>...   sequential merge + gate + rollback
  check [manifest]         validate the ownership manifest (disjoint claims)
  gate-check [--quiet]     assert the pre-push merge gate is still wired (core.hooksPath)
  install-hooks            wire .githooks via core.hooksPath
  ruleset [owner/repo]     create the protect-main GitHub ruleset
  uninstall [--force]      cleanly remove claude-fleet from this repo
EOF
    ;;
  *) echo "unknown command: $cmd (try: fleet --help)" >&2; exit 2 ;;
esac
