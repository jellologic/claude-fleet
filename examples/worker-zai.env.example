# examples/worker-zai.env.example — provider presets for `fleet delegate` workers (#23)
#
#   source examples/worker-zai.env.example      # after editing, and NEVER commit a real token
#   .fleet/bin/fleet delegate delegate agent/issue-42 "…task…"
#
# ── The core insight: the worker is a SEPARATE PROCESS ────────────────────────────────
# ANTHROPIC_BASE_URL and ANTHROPIC_AUTH_TOKEN are GLOBAL PER PROCESS. There is no way to
# route one model tier to one provider and another tier somewhere else inside a single
# Claude Code process — one process, one endpoint, one credential. That is exactly why
# delegation makes multi-provider work possible: `fleet delegate` spawns the worker as its
# OWN process, so the worker's provider is whatever FLEET_WORKER_* says here, entirely
# independent of the orchestrator you are sitting in. The orchestrator can stay on Opus
# while the worker runs on a cheap gateway model; they are not sharing an endpoint.
#
# The FLEET_WORKER_* vars below are mapped by src/fleet/bin/agent-delegate.sh onto the
# CHILD's environment. Nothing here is Anthropic-specific: point it at any
# Anthropic-compatible gateway.
#
#   FLEET_WORKER_BASE_URL   → ANTHROPIC_BASE_URL
#   FLEET_WORKER_TOKEN_FILE → (contents) → ANTHROPIC_AUTH_TOKEN
#   FLEET_WORKER_MODEL      → ANTHROPIC_DEFAULT_{OPUS,SONNET,HAIKU}_MODEL + ANTHROPIC_MODEL
#   FLEET_WORKER_TIMEOUT_MS → API_TIMEOUT_MS
#
# ── SECRETS ───────────────────────────────────────────────────────────────────────────
# NEVER put a token in this file, in any committed file, or on a command line (it would
# show up in `ps` and in every shell history). Put it in a mode-600 file and point
# FLEET_WORKER_TOKEN_FILE at it; agent-delegate reads it and passes it to the worker
# through the environment only, and warns loudly if the file is not 600:
#
#   printf '%s' 'YOUR_REAL_TOKEN_HERE' > "$HOME/.claudez_token"
#   chmod 600 "$HOME/.claudez_token"

# ── Preset A — z.ai / GLM via the Anthropic-compatible gateway (the motivating case) ──
export FLEET_WORKER_BASE_URL=https://api.z.ai/api/anthropic
export FLEET_WORKER_MODEL=glm-5.2
export FLEET_WORKER_TOKEN_FILE=$HOME/.claudez_token     # mode 600, PLACEHOLDER — not in the repo
export FLEET_WORKER_TIMEOUT_MS=3000000

# ── Preset B — Anthropic default (just leave everything unset) ───────────────────────
# The worker then inherits whatever the ambient Claude Code install is already using —
# same auth, same endpoint, same models as the orchestrator. Delegation still buys you the
# separate process, the worktree confinement and the headless loop; it just is not cheaper.
#
#   unset FLEET_WORKER_BASE_URL FLEET_WORKER_MODEL FLEET_WORKER_TOKEN_FILE FLEET_WORKER_TOKEN

# ── Confinement (fail closed) ────────────────────────────────────────────────────────
# The worker runs with --dangerously-skip-permissions, so it is wrapped in an OS sandbox
# (macOS `sandbox-exec`). fleet's Python write-guard is a Write/Edit-only rail — it does
# NOT bind subprocesses — so the sandbox is the confinement rail. Default is 1 (required);
# if it is unavailable, `fleet delegate` DIES rather than run a worker unconfined.
export FLEET_DELEGATE_SANDBOX=1
# export FLEET_DELEGATE_RETRIES=4     # attempts per invocation on 429/529/transport errors
